# CA-Copilot Environment Variables

# API Configuration
PROJECT_NAME="CA-Copilot"
SECRET_KEY="replace-this-with-a-very-long-random-string" # openssl rand -hex 32
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# Database Configuration
DATABASE_URL="postgresql+asyncpg://postgres:password@db:5432/cacopilot"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cacopilot

# Document Parsing (LlamaParse OCR — only API key needed)
LLAMA_CLOUD_API_KEY="llx-..."

# Supabase Storage Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"
SUPABASE_BUCKET="knowledge-kits"

# Google OAuth (for Google Sign-In)
GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# Production Settings
APP_RELOAD="false"
